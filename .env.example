# GitHub Personal Access Token
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ============================================================
# MySQL 配置（分离参数，支持连接池）
# ============================================================
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root123
MYSQL_DB_NAME=osint

# MySQL 连接池配置（高并发对话关键参数）
# 每个对话占用 2 连接（checkpointer + store）
# 支持 100 并发对话 → 需要 200+ 连接池
MYSQL_POOL_MINSIZE=20
MYSQL_POOL_MAXSIZE=200

# ============================================================
# LLM 高并发配置（对话 QPS 关键参数）
# ============================================================

# LLM 最大并发请求数
# 建议: 100（支持 100 个对话同时进行 LLM 调用）
LLM_MAX_CONCURRENCY=100

# LLM 请求超时（秒）
# 建议: 120（深度分析可能需要较长时间）
LLM_REQUEST_TIMEOUT=120

# Rate Limiter 配置（令牌桶限速）
# 默认 2.0 QPS，支持 100 并发对话（100/90s ≈ 1.1 QPS）
RATE_LIMIT_REQUESTS_PER_SECOND=2.0
RATE_LIMIT_CHECK_EVERY_SECONDS=0.1
RATE_LIMIT_MAX_BUCKET_SIZE=10.0

# ============================================================
# SSE 流式对话配置
# ============================================================

# SSE 最大并发连接数
# 建议: 500（高峰时段 200 对话 + 冗余）
SSE_MAX_CONNECTIONS=500

# SSE 连接空闲超时（秒）
# 建议: 300（5 分钟无活动则断开）
SSE_IDLE_TIMEOUT=300

# OpenSandbox Server Configuration
OPEN_SANDBOX_API_URL=http://localhost:8080
OPEN_SANDBOX_API_KEY=

# ============================================================
# 沙箱配置（生命周期管理）
# ============================================================

# 沙箱镜像（必须使用定制镜像，依赖已预装）
SANDBOX_IMAGE=sandbox-registry.cn-zhangjiakou.cr.aliyuncs.com/osint/osint-sandbox:v1.0.0

# 沙箱启动重试配置
REUSE_SANDBOX_RETRIES=3
MAX_SANDBOX_WAIT_RETRIES=36

# 沙箱缓存过期时间（小时）
SANDBOX_MAX_AGE_HOURS=24

# 运行时健康检查重试次数（执行命令时沙箱失效）
RUNTIME_HEALTH_RETRIES=2

# 是否通过 server 代理访问 execd
# macOS + colima 环境：必须设为 true
USE_SERVER_PROXY=true

# ========== 百炼大模型平台配置（阿里云 DashScope） ==========
# API Key（从百炼平台获取：https://bailian.console.aliyun.com/）
DASHSCOPE_API_KEY=sk-your-bailian-api-key

# API Base URL（百炼 OpenAI 兼容接口）
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# Agent Configuration
# 主Agent模型（百炼平台模型）
# 通义千问系列: openai:qwen-turbo, openai:qwen-plus, openai:qwen-max, openai:qwen-max-longcontext
# 其他百炼模型: openai:deepseek-r1, openai:deepseek-v3
AGENT_MODEL=openai:qwen-plus

# 子Agent 配置目录
SUBAGENTS_DIR=./subagents

# 日志级别
LOG_LEVEL=INFO

# ============================================================
# 扫描器配置（超时、重试、并发控制）
# ============================================================

# 单个子任务最大执行时间（秒）
# 建议: 60秒（覆盖大部分正常扫描场景）
SCAN_SUBTASK_TIMEOUT=60

# GitHub API 单次调用超时（秒）
# 建议: 30秒（GitHub API 响应较慢时可能需要更长）
SCAN_GITHUB_API_TIMEOUT=30

# OSV.dev API 调用超时（秒）
SCAN_OSV_API_TIMEOUT=15

# 失败重试次数
# 建议: 1次（避免过度重试消耗资源）
SCAN_MAX_RETRIES=1

# 重试前等待时间（秒）
SCAN_RETRY_DELAY=5

# 失败率阈值（超过此比例终止整个扫描）
# 建议: 0.3（30%失败率）
SCAN_FAILURE_THRESHOLD=0.3

# 并发控制 - 最大同时扫描仓库数
# 建议: 20（GitHub API 速率限制约5000次/小时，20并发可充分利用）
SCAN_MAX_CONCURRENCY=20

# 扫描进度检查频率（秒）
# 建议: 1.0（每秒检查暂停状态和失败率）
SCAN_PROGRESS_CHECK_INTERVAL=1.0

# ============================================================
# Redis 配置（分布式锁）
# ============================================================
# Redis 连接 URL
REDIS_URL=redis://localhost:6379/0

# 锁过期时间（秒）- 防止服务崩溃导致死锁
REDIS_LOCK_TIMEOUT=3600

# ============================================================
# 预警通知渠道配置
# ============================================================

# --- 中国企业渠道 ---
# 钉钉机器人 Webhook（https://oapi.dingtalk.com/robot/send?access_token=xxx）
DINGTALK_WEBHOOK=
DINGTALK_SECRET=  # 加签密钥（可选，用于安全验证）

# 飞书/Lark机器人 Webhook（https://open.feishu.cn/open-apis/bot/v2/hook/xxx）
FEISHU_WEBHOOK=

# --- 国际化渠道 ---
# Slack Webhook（https://hooks.slack.com/services/Txxx/Bxxx/xxx）
SLACK_WEBHOOK=
SLACK_CHANNEL=  # 可选，指定频道如 #alerts

# Discord Webhook（https://discord.com/api/webhooks/xxx/xxx）
DISCORD_WEBHOOK=

# --- Email渠道 ---
# SMTP服务器配置
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=alerts@example.com
EMAIL_TO=user1@example.com,user2@example.com  # 多个收件人用逗号分隔